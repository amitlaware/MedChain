# backend/.env — Copy to .env and fill in secrets

# Server
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=change-me-to-a-very-long-random-string-in-production
JWT_EXPIRES=24h

# Hyperledger Fabric
FABRIC_CHANNEL=ehr-channel
FABRIC_CHAINCODE=ehr-chaincode

# IPFS (local Kubo node)
IPFS_HOST=localhost
IPFS_PORT=5001
IPFS_PROTO=http

# IPFS via Infura (optional — comment out local settings above)
# IPFS_PROJECT_ID=your-infura-project-id
# IPFS_PROJECT_SECRET=your-infura-project-secret

# AWS S3 (optional backup storage)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=ehr-healthcare-bucket
