# Example environment variables used by docker-compose
# Copy this file to .env and fill values before running `docker-compose up --build`

# MongoDB admin credentials (used for initial DB creation)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=adminpassword

# CouchDB admin credentials
COUCHDB_USER=admin
COUCHDB_PASSWORD=adminpassword

# IPFS encryption key (hex 64 chars or passphrase)
IPFS_ENCRYPTION_KEY=change_this_to_a_strong_secret_or_hex_64_chars

# Optional: override API URL for frontend
VITE_API_URL=http://localhost:5000/api
